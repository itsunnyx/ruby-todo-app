<%= form_with(model: task, class: "space-y-5") do |form| %>
  <% if task.errors.any? %>
    <div class="rounded-xl bg-red-50 p-4 text-red-700">
      <h2 class="font-semibold"><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>

      <ul class="list-disc ml-5 mt-2">
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :title,
      placeholder: "e.g. Finish Rails todo app",
      class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :description,
      rows: 4,
      placeholder: "Add more detail about this task...",
      class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :status,
        [["Pending", "pending"], ["In progress", "in_progress"], ["Completed", "completed"], ["Cancelled", "cancelled"]],
        {},
        class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :due_date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :due_date,
        class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <div>
      <%= form.label :priority, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :priority,
        [["Low", "low"], ["Medium", "medium"], ["High", "high"]],
        { include_blank: "Select priority" },
        class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :category,
        [["Inbox", "inbox"], ["Personal", "personal"], ["Work", "work"], ["Home", "home"]],
        { include_blank: "Select category" },
        class: "w-full rounded-xl border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3 pt-4">
    <%= link_to "Cancel", tasks_path,
      class: "px-4 py-2 rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium" %>

    <%= form.submit class: "px-5 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>

    <%= link_to "Cancel", tasks_path,
    data: { turbo_frame: "_top" },
    class: "px-4 py-2 rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium" %>
  </div>
<% end %>