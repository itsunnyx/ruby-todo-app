<% content_for :title, "Tasks" %>

<div class="h-screen w-screen overflow-hidden bg-white">
  <div class="grid h-full grid-cols-[280px_1fr_420px]">

    <!-- Sidebar -->
    <aside class="bg-white border-r border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-6">Todo App</h2>

      <nav class="space-y-2">
        <%= link_to "📥 Inbox", tasks_path,
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>

        <%= link_to "📅 Today", tasks_path(filter: "today"),
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>

        <%= link_to "🗓 Next 7 Days", tasks_path(filter: "next7"),
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>
      </nav>

      <div class="border-t border-gray-200 my-6"></div>

      <p class="text-sm font-semibold text-gray-400 mb-3">Lists</p>

      <nav class="space-y-2">
        <%= link_to "🐱 Personal", tasks_path(category: "personal"),
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>

        <%= link_to "💻 Work", tasks_path(category: "work"),
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>

        <%= link_to "🏠 Home", tasks_path(category: "home"),
          class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>
      </nav>

      <div class="border-t border-gray-200 my-6"></div>

      <%= link_to "👤 Profile", profile_path,
        class: "block px-3 py-2 rounded-lg hover:bg-gray-100" %>
    </aside>

    <!-- Task List -->
    <main class="bg-white border-r border-gray-200 p-7 overflow-y-auto">
      <% if notice.present? %>
        <p class="py-2 px-3 bg-green-50 mb-5 text-green-600 font-medium rounded-md inline-block">
          <%= notice %>
        </p>
      <% end %>

      <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold">
          <%= params[:filter] == "today" ? "Today" : params[:filter] == "next7" ? "Next 7 Days" : params[:category].present? ? params[:category].capitalize : "Inbox" %>
        </h1>

        <%= link_to "+ Add task", new_task_path,
          data: { turbo_frame: "modal" },
          class: "px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
      </div>

      <div class="space-y-2">
        <% if @tasks.any? %>
          <% @tasks.each do |task| %>
            <div class="flex items-center gap-3 px-3 py-3 rounded-lg hover:bg-gray-50 border-b border-gray-100">
              <div class="w-5 h-5 rounded border-2 border-gray-300"></div>

              <div class="flex-1">
                <div class="font-medium text-gray-800"><%= task.title %></div>

                <div class="mt-1 flex gap-2 text-xs text-gray-400">
                  <% if task.status.present? %>
                    <span><%= task.status %></span>
                  <% end %>

                  <% if task.priority.present? %>
                    <span>• <%= task.priority %></span>
                  <% end %>

                  <% if task.category.present? %>
                    <span>• <%= task.category %></span>
                  <% end %>
                </div>
              </div>

              <% if task.due_date.present? %>
                <span class="text-sm text-blue-600">
                  <%= task.due_date == Date.current ? "Today" : task.due_date.strftime("%d %b") %>
                </span>
              <% end %>

              <%= link_to "Open", tasks_path(request.query_parameters.merge(selected_id: task.id)),
                class: "text-sm text-blue-600 hover:underline" %>
            </div>
          <% end %>
        <% else %>
          <p class="text-center text-gray-400 mt-24">No tasks found.</p>
        <% end %>
      </div>
    </main>

    <!-- Detail Panel -->
    <section class="bg-white p-7 overflow-y-auto">
      <% selected_task = params[:selected_id].present? ? Task.find_by(id: params[:selected_id]) : @tasks.first %>

      <% if selected_task.present? %>
        <div class="flex justify-between items-start mb-6">
          <div class="text-blue-600 text-sm">
            <%= selected_task.due_date.present? ? selected_task.due_date.strftime("%b %d") : "No due date" %>
          </div>

          <%= link_to "Edit", edit_task_path(selected_task),
            class: "px-3 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-sm" %>
        </div>

        <h2 class="text-2xl font-bold mb-3"><%= selected_task.title %></h2>

        <p class="text-gray-600 mb-8">
          <%= selected_task.description.presence || "No description" %>
        </p>

        <div class="space-y-4">
          <div class="flex justify-between border-b pb-3">
            <span>Status</span>
            <span><%= selected_task.status %></span>
          </div>

          <div class="flex justify-between border-b pb-3">
            <span>Priority</span>
            <span><%= selected_task.priority.presence || "-" %></span>
          </div>

          <div class="flex justify-between border-b pb-3">
            <span>Category</span>
            <span><%= selected_task.category.presence || "-" %></span>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          <% if selected_task.may_start? %>
            <%= button_to "Start", start_task_path(selected_task),
              method: :patch,
              class: "px-3 py-2 bg-yellow-500 hover:bg-yellow-400 text-white rounded-lg text-sm" %>
          <% end %>

          <% if selected_task.may_complete? %>
            <%= button_to "Complete", complete_task_path(selected_task),
              method: :patch,
              class: "px-3 py-2 bg-green-600 hover:bg-green-500 text-white rounded-lg text-sm" %>
          <% end %>

          <% if selected_task.may_cancel? %>
            <%= button_to "Cancel", cancel_task_path(selected_task),
              method: :patch,
              class: "px-3 py-2 bg-gray-600 hover:bg-gray-500 text-white rounded-lg text-sm" %>
          <% end %>

          <%= button_to "Delete", selected_task,
            method: :delete,
            data: { turbo_confirm: "Are you sure?" },
            class: "px-3 py-2 bg-red-600 hover:bg-red-500 text-white rounded-lg text-sm" %>
        </div>
      <% else %>
        <div class="h-full flex items-center justify-center text-gray-400">
          Select a task to view details
        </div>
      <% end %>
    </section>

  </div>
</div>

<%= turbo_frame_tag "modal" %>